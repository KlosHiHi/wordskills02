        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Formulation.IsCurrent)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Formulation.Product)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Formulation.Product.Id)
