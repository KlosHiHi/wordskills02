@page
@model WebApp1.Pages.FormulationItems.EditModel

@{
    ViewData["Title"] = "FormulationUtemsEdit";
}



<h4>FormulationItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="FormulationItem.FormulationId" />
            <input type="hidden" asp-for="FormulationItem.ItemId" />
            <div class="form-group">
                <label asp-for="FormulationItem.Quantity" class="control-label"></label>
                <input asp-for="FormulationItem.Quantity" class="form-control" />
                <span asp-validation-for="FormulationItem.Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
