<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaApplication.ViewModels"
             x:DataType="vm:FormulationsViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication.Views.FormulationsView">
            <DockPanel>
              <DataGrid DoubleTapped="DataGrid_DoubleTapped" ItemsSource="{Binding Formulations}">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                  <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                  <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                  <DataGridTextColumn Header="Продукт" Binding="{Binding Product}" Width="*"/>
                  <DataGridTextColumn Header="Текущий" Binding="{Binding IsCurrent}" Width="*"/>
                  <DataGridTemplateColumn Header="Действия" Width="*">
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <Button Content="✏️" Width="35" Height="35" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        <Button Content="🗑️" Width="35" Height="35" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
              <DockPanel>
              </DockPanel>
            </DockPanel>
</UserControl>
