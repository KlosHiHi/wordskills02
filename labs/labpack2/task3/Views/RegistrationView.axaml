<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:task3.ViewModels"
             x:DataType="vm:RegistrationViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="task3.Views.RegistrationView">  
    <StackPanel HorizontalAlignment="Center">
        <TextBox Text="{Binding Login}" Margin="5" Width="200" Watermark="Логин" TextInputOptions.ContentType="Name"/>
        <TextBox Margin="5" Width="200" Watermark="Пароль" TextInputOptions.ContentType="Password"/>
        <TextBox Margin="5" Width="200" Watermark="Подтверждение пароль" TextInputOptions.ContentType="Password"/>
        <TextBox Margin="5" Width="200" Watermark="Email" TextInputOptions.ContentType="Email"/>
        <TextBox Margin="5" Width="200" Watermark="Номер телефона" TextInputOptions.ContentType="Number"/>
        <Button Command="{Binding RegistrationCommand}" Margin="5" Content="Зарегистрироваться" Width="200" HorizontalContentAlignment="Center"/>
    </StackPanel>
</UserControl>
