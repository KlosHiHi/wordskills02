<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:task1.ViewModels"
             x:DataType="vm:DBManagerViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="task1.Views.DBManagerView">
    <DockPanel>
		<StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Top">
			<TextBox Watermark="Логин" Width="150" Margin="5"/>
			<TextBox Watermark="Пароль" Width="150" Margin="5"/>
            <Button Command="{Binding InsertUserCommand}" Content="Создать"/>
        </StackPanel>
        <DataGrid IsReadOnly="True" ItemsSource="{Binding Users}">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Id" Binding="{Binding Id}"/>
				<DataGridTextColumn Header="Login" Binding="{Binding Login}"/>
				<DataGridTextColumn Header="Password" Binding="{Binding Password}"/>
                <DataGridTemplateColumn>
					<DataTemplate>
						<Button Command="{Binding $parent[UserControl].((vm:DBManagerViewModel)DataContext).DeleteCommand}" CommandParameter="{Binding Id}" Content="Удалить"/>
                    </DataTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>