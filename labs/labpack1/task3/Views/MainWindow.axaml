<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:task3.ViewModels"
        xmlns:local="using:task3.Views"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="task3.Views.MainWindow"
        Title="task3">
    <DockPanel>
		<StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center" VerticalAlignment="Center">
		    <Button Command="{Binding OpenAuthPageCommand}" Margin="5" Content="Авторизоваться" Width="200" HorizontalContentAlignment="Center"/>
		    <Button Command="{Binding OpenRegPageCommand}" Margin="5" Content="Зарегистрироваться" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>
        <ContentControl Content="{Binding CurrentPage}"/>
    </DockPanel>
    
</Window>
